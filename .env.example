# TransLingua Configuration Example
# ===================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env with real API keys to version control!

# LLM Translation Settings
# ========================
USE_LLM=true
LLM_API_KEY=your_groq_api_key_here  # Get from https://console.groq.com
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Server Settings (Render-specific)
# ==================================
HOST=0.0.0.0
PORT=10000

# OCR Settings (Linux/Render)
# ============================
TESSERACT_CMD=tesseract  # On Linux/Render, use just 'tesseract'
# On Windows, use: C:\Program Files\Tesseract-OCR\tesseract.exe

# Debug Mode
DEBUG=false

# Alternative: Using OpenAI instead of Groq
# ==========================================
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
